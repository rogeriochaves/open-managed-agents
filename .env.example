# LLM Provider API Keys (at least one required, or use Ollama)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
# OPENAI_API_KEY=sk-proj-your-key-here

# Optional: Encryption key for vault credential storage (auto-generated on first run)
# VAULT_ENCRYPTION_KEY=

# Optional: Server port (default: 3001)
# PORT=3001

# Optional: SQLite database path (default: data/oma.db)
# DATABASE_PATH=data/oma.db

# Optional: Path to governance config file for infra-as-code deployments
# GOVERNANCE_CONFIG=governance.json
