# ── Build stage ─────────────────────────────────────────────────────────────
FROM node:25-slim AS build
RUN corepack enable pnpm

WORKDIR /app
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY packages/types/package.json packages/types/
COPY packages/server/package.json packages/server/
RUN pnpm install --frozen-lockfile

COPY tsconfig.base.json ./
COPY packages/types/ packages/types/
COPY packages/server/ packages/server/

RUN pnpm --filter @open-managed-agents/types build
RUN pnpm --filter @open-managed-agents/server build

# Drop dev deps to shrink the final image
RUN pnpm --filter @open-managed-agents/server deploy --prod /oma-server

# ── Runtime stage ───────────────────────────────────────────────────────────
FROM node:25-slim AS runtime

# curl is needed for the HEALTHCHECK below
RUN apt-get update \
 && apt-get install -y --no-install-recommends curl ca-certificates \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=build /oma-server/package.json ./package.json
COPY --from=build /oma-server/node_modules ./node_modules
COPY --from=build /oma-server/dist ./dist

# Writable data dir for the SQLite file (ignored when DATABASE_URL is postgres)
RUN mkdir -p /app/data && chown -R node:node /app
USER node

EXPOSE 3001

HEALTHCHECK --interval=15s --timeout=5s --start-period=10s --retries=3 \
  CMD curl -fsS http://localhost:${PORT:-3001}/health >/dev/null || exit 1

CMD ["node", "dist/index.js"]
