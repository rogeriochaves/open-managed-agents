# ── Build stage ─────────────────────────────────────────────────────────────
FROM node:22-slim AS build
RUN corepack enable pnpm

WORKDIR /app
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY packages/types/package.json packages/types/
COPY packages/web/package.json packages/web/
RUN pnpm install --frozen-lockfile

COPY tsconfig.base.json ./
COPY packages/types/ packages/types/
COPY packages/web/ packages/web/

RUN pnpm --filter @open-managed-agents/types build
RUN pnpm --filter @open-managed-agents/web build

# ── Runtime stage ───────────────────────────────────────────────────────────
FROM nginx:alpine AS runtime

# Install curl for the HEALTHCHECK
RUN apk add --no-cache curl

COPY --from=build /app/packages/web/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

# nginx:alpine already has a non-root `nginx` user; run as it.
# (Master process still starts as root to bind port 80, then drops.)
EXPOSE 80

HEALTHCHECK --interval=15s --timeout=5s --start-period=5s --retries=3 \
  CMD curl -fsS http://localhost/ >/dev/null || exit 1
