{
  "name": "open-managed-agents",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"pnpm --filter @open-managed-agents/server dev\" \"pnpm --filter @open-managed-agents/web dev\"",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "ws": "^8.20.0"
  }
}
